{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cline.sh/bench/schema/run-v1.schema.json",
  "title": "bench run report v1",
  "type": "object",
  "required": ["results", "comparison", "metadata"],
  "properties": {
    "results": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/benchmarkResult"
      }
    },
    "comparison": {
      "type": "object",
      "required": ["rows", "geometric_mean_reference_gap"],
      "properties": {
        "rows": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/runComparisonRow"
          }
        },
        "geometric_mean_reference_gap": {
          "type": "number"
        }
      },
      "additionalProperties": true
    },
    "metadata": {
      "$ref": "#/$defs/reportMetadata"
    }
  },
  "additionalProperties": true,
  "$defs": {
    "environment": {
      "type": "object",
      "required": [
        "php_version",
        "php_sapi",
        "os_family",
        "architecture",
        "extensions"
      ],
      "properties": {
        "php_version": {
          "type": "string"
        },
        "php_sapi": {
          "type": "string"
        },
        "os_family": {
          "type": "string"
        },
        "architecture": {
          "type": "string"
        },
        "extensions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "settings": {
      "type": "object",
      "properties": {
        "process_isolation": {
          "type": "boolean"
        },
        "default_iterations": {
          "type": "integer"
        },
        "default_revolutions": {
          "type": "integer"
        },
        "default_warmup_iterations": {
          "type": "integer"
        },
        "significance_enabled": {
          "type": "boolean"
        },
        "significance_alpha": {
          "type": "number"
        },
        "significance_minimum_samples": {
          "type": "integer"
        }
      },
      "additionalProperties": true
    },
    "selection": {
      "type": "object",
      "required": ["filter", "groups", "competitors"],
      "properties": {
        "filter": {
          "type": ["string", "null"]
        },
        "groups": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "competitors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "summary": {
      "type": "object",
      "required": [
        "samples",
        "min",
        "max",
        "mean",
        "median",
        "standard_deviation",
        "relative_margin_of_error",
        "percentile75",
        "percentile95",
        "percentile99",
        "operations_per_second"
      ],
      "properties": {
        "samples": {
          "type": "integer"
        },
        "min": {
          "type": "number"
        },
        "max": {
          "type": "number"
        },
        "mean": {
          "type": "number"
        },
        "median": {
          "type": "number"
        },
        "standard_deviation": {
          "type": "number"
        },
        "relative_margin_of_error": {
          "type": "number"
        },
        "percentile75": {
          "type": "number"
        },
        "percentile95": {
          "type": "number"
        },
        "percentile99": {
          "type": "number"
        },
        "operations_per_second": {
          "type": "number"
        }
      },
      "additionalProperties": true
    },
    "threshold": {
      "type": "object",
      "required": ["metric", "operator", "expected", "actual", "passed"],
      "properties": {
        "metric": {
          "type": "string"
        },
        "operator": {
          "type": "string"
        },
        "expected": {
          "type": "number"
        },
        "actual": {
          "type": "number"
        },
        "passed": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "regression": {
      "type": "object",
      "required": ["metric", "tolerance"],
      "properties": {
        "metric": {
          "type": ["string", "null"]
        },
        "tolerance": {
          "type": ["string", "null"]
        }
      },
      "additionalProperties": true
    },
    "significance": {
      "type": "object",
      "required": ["status", "label", "p_value", "alpha", "minimum_samples"],
      "properties": {
        "status": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "p_value": {
          "type": ["number", "null"]
        },
        "alpha": {
          "type": ["number", "null"]
        },
        "minimum_samples": {
          "type": ["integer", "null"]
        }
      },
      "additionalProperties": true
    },
    "benchmarkResult": {
      "type": "object",
      "required": [
        "subject",
        "scenario",
        "competitor",
        "summary",
        "samples",
        "parameters",
        "case_label",
        "parameter_label",
        "groups",
        "thresholds",
        "regression"
      ],
      "properties": {
        "subject": {
          "type": "string"
        },
        "scenario": {
          "type": "string"
        },
        "competitor": {
          "type": "string"
        },
        "summary": {
          "$ref": "#/$defs/summary"
        },
        "samples": {
          "type": "array",
          "items": {
            "type": "number"
          }
        },
        "parameters": {
          "type": "object"
        },
        "case_label": {
          "type": ["string", "null"]
        },
        "parameter_label": {
          "type": "string"
        },
        "groups": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "thresholds": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/threshold"
          }
        },
        "regression": {
          "$ref": "#/$defs/regression"
        }
      },
      "additionalProperties": true
    },
    "runComparisonRow": {
      "type": "object",
      "required": [
        "scenario",
        "subject",
        "competitor",
        "parameters",
        "winner",
        "delta_percentage",
        "reference_gap",
        "reference_gain",
        "significance"
      ],
      "properties": {
        "scenario": {
          "type": "string"
        },
        "subject": {
          "type": "string"
        },
        "competitor": {
          "type": "string"
        },
        "parameters": {
          "type": "object"
        },
        "winner": {
          "type": "string"
        },
        "delta_percentage": {
          "type": "number"
        },
        "reference_gap": {
          "type": "number"
        },
        "reference_gain": {
          "type": "number"
        },
        "significance": {
          "$ref": "#/$defs/significance"
        }
      },
      "additionalProperties": true
    },
    "reportMetadata": {
      "type": "object",
      "required": ["schema_version", "report_type", "generated_at"],
      "properties": {
        "schema_version": {
          "const": 1
        },
        "report_type": {
          "const": "run"
        },
        "generated_at": {
          "type": "string"
        },
        "environment": {
          "$ref": "#/$defs/environment"
        },
        "settings": {
          "$ref": "#/$defs/settings"
        },
        "selection": {
          "$ref": "#/$defs/selection"
        }
      },
      "additionalProperties": true
    }
  }
}
